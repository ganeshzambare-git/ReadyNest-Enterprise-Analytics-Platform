# ============================================================
# ReadyNest Dashboard — Environment Variables Template
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.
# ============================================================

# --- PostgreSQL ---
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=readynest_db
PG_USER=postgres
PG_PASSWORD=your_password_here

# --- MySQL ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=readynest_db
MYSQL_USER=root
MYSQL_PASSWORD=your_password_here

# --- App Settings ---
LOG_LEVEL=INFO
MAX_PREVIEW_ROWS=10
EXPORT_DIR=exports
